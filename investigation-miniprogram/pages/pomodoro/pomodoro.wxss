/* pages/pomodoro/pomodoro.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background-color);
}

.timer-card {
  margin: 24rpx;
  padding: 32rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
}

.timer-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
}

.time {
  font-size: 72rpx;
  font-weight: bold;
  color: var(--text-color);
  line-height: 1;
}

.status {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.current-task {
  margin-top: 32rpx;
  padding: 16rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
}

.task-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 32rpx;
  color: var(--text-color);
}

.timer-controls {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.control-btn {
  flex: 1;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-size: 32rpx;
}

.control-icon {
  font-size: 36rpx;
}

.control-label {
  font-size: 24rpx;
}

.stats-card {
  margin-top: 24rpx;
  padding: 32rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
}

.stats-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.stats-grid {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.history-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.session-list {
  margin-top: 16rpx;
}

.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.session-time {
  font-size: 26rpx;
  color: var(--text-color);
  flex: 1;
}

.session-duration {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.session-task {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}
