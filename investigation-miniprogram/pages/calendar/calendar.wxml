<!-- pages/calendar/calendar.wxml -->
<view class="page">
  <!-- 顶部Tab切换 -->
  <view class="tab-switch">
    <view class="tab-item {{viewMode === 'month' ? 'active' : ''}}" bindtap="onMonthView">月</view>
    <view class="tab-item {{viewMode === 'week' ? 'active' : ''}}" bindtap="onWeekView">周</view>
    <view class="tab-item {{viewMode === 'day' ? 'active' : ''}}" bindtap="onDayView">日</view>
  </view>

  <!-- 日期导航 -->
  <view class="date-nav">
    <view class="nav-btn" bindtap="onPrevMonth">‹</view>
    <view class="current-date">{{currentMonth}}</view>
    <view class="nav-btn" bindtap="onNextMonth">›</view>
  </view>

  <!-- 日历网格 -->
  <view class="calendar-grid">
    <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
    <view class="calendar-days">
      <view class="day-cell" wx:for="{{days}}" wx:key="*this">
        <view class="day-number {{item.isToday ? 'today' : ''}}">{{item.date}}</view>
        <view class="task-dots">
          <view class="task-dot" wx:for="{{item.tasks}}" wx:key="*this"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 当天任务 -->
  <view class="day-tasks" wx:if="{{todayTasks.length > 0}}">
    <view class="section-title">今天 {{todayDate}} ({{todayTasks.length}}个任务)</view>
    <view class="task-list">
      <view class="task-item" wx:for="{{todayTasks}}" wx:key="id">
        <view class="task-priority priority-{{item.priority}}"></view>
        <view class="task-info">
          <view class="task-title">{{item.title}}</view>
          <view class="task-meta">
            <text wx:if="{{item.due_time}}">⏰ {{item.due_time}}</text>
            <text wx:if="{{item.list_name}}">📋 {{item.list_name}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
