/* pages/habits/habits.wxss */
.page {
  min-height: 100vh;
  background-color: var(--background-color);
  padding-bottom: 24rpx;
}

.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
}

.stats-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.stats-grid {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.habit-list {
  margin: 24rpx;
}

.habit-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
}

.habit-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background-color: var(--background-color);
  border-radius: 50%;
  margin-right: 24rpx;
}

.habit-content {
  flex: 1;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.habit-streak {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.habit-streak text {
  color: var(--primary-color);
  font-weight: bold;
}

.checkin-btn {
  padding: 16rpx 32rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.checkin-btn.checked {
  background-color: var(--success-color);
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
  z-index: 1000;
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  line-height: 1;
}
