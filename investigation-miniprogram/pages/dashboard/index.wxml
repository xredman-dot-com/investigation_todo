<view class="container">
  <view class="section card">
    <view class="title">今日概览</view>
    <view class="subtitle">聚焦现在，积累格物</view>
    <view class="row" style="margin-top: 16rpx;">
      <view>
        <view class="badge">待办 {{summary ? summary.active_tasks_count : 0}}</view>
      </view>
      <view>
        <view class="badge">今日到期 {{summary ? summary.tasks_due_today_count : 0}}</view>
      </view>
      <view>
        <view class="badge">逾期 {{summary ? summary.tasks_overdue_count : 0}}</view>
      </view>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <view class="subtitle">习惯 {{summary ? summary.habits_completed : 0}} / {{summary ? summary.habits_total : 0}}</view>
      <view class="subtitle">专注 {{summary ? summary.focus_minutes : 0}} 分钟</view>
    </view>
  </view>

  <view class="section card">
    <view class="title">今日任务</view>
    <view class="subtitle">到期任务速览</view>
    <view class="list-item" wx:for="{{summary ? summary.tasks_due_today : []}}" wx:key="id">
      <view class="row">
        <view>{{item.title}}</view>
        <view class="subtitle">{{item.due_time || ""}}</view>
      </view>
    </view>
    <view wx:if="{{summary && summary.tasks_due_today.length === 0}}" class="subtitle">暂无到期任务</view>
  </view>

  <view class="section card">
    <view class="title">逾期任务</view>
    <view class="subtitle">尽快处理</view>
    <view class="list-item" wx:for="{{summary ? summary.tasks_overdue : []}}" wx:key="id">
      <view class="row">
        <view>{{item.title}}</view>
        <view class="subtitle">{{item.due_date || ""}}</view>
      </view>
    </view>
    <view wx:if="{{summary && summary.tasks_overdue.length === 0}}" class="subtitle">暂无逾期任务</view>
  </view>

  <view class="section card">
    <view class="title">快捷入口</view>
    <view class="row" style="flex-wrap: wrap; margin-top: 12rpx;">
      <view
        wx:for="{{quickActions}}"
        wx:key="label"
        data-url="{{item.url}}"
        bindtap="goTo"
        class="tag"
        style="margin: 6rpx 8rpx;"
      >
        {{item.label}}
      </view>
    </view>
  </view>
</view>
