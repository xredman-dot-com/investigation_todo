<view class="container">
  <view class="section card">
    <view class="title">基础信息</view>
    <picker mode="selector" range="{{lists}}" range-key="name" value="{{listIndex}}" bindchange="onListChange">
      <view class="input" style="margin-top: 12rpx;">清单：{{lists[listIndex] ? lists[listIndex].name : ''}}</view>
    </picker>
    <input class="input" style="margin-top: 12rpx;" placeholder="任务标题" value="{{form.title}}" data-field="title" bindinput="onInputChange" />
    <textarea class="input" style="margin-top: 12rpx;" placeholder="描述" value="{{form.description}}" data-field="description" bindinput="onInputChange"></textarea>
    <textarea class="input" style="margin-top: 12rpx;" placeholder="意义（可选）" value="{{form.meaning}}" data-field="meaning" bindinput="onInputChange"></textarea>
    <input class="input" style="margin-top: 12rpx;" placeholder="标签（逗号分隔）" value="{{form.tagsText}}" data-field="tagsText" bindinput="onInputChange" />
  </view>

  <view class="section card">
    <view class="title">时间与优先级</view>
    <view class="row" style="margin-top: 12rpx;">
      <picker mode="date" value="{{form.due_date}}" bindchange="onDateChange">
        <view class="input">日期：{{form.due_date || '未设置'}}</view>
      </picker>
      <picker mode="time" value="{{form.due_time}}" bindchange="onTimeChange">
        <view class="input">时间：{{form.due_time || '未设置'}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <picker mode="selector" range="{{priorityOptions}}" value="{{form.priority}}" bindchange="onPriorityChange">
        <view class="input">优先级：P{{form.priority}}</view>
      </picker>
      <picker mode="selector" range="{{eisenhowerOptions}}" value="{{quadrantIndex}}" bindchange="onQuadrantChange">
        <view class="input">象限：{{form.eisenhower_quadrant || '自动'}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <view class="subtitle">重要</view>
      <switch checked="{{form.is_important}}" data-field="is_important" bindchange="onSwitchChange" />
    </view>
  </view>

  <view class="section card">
    <view class="title">重复规则</view>
    <view class="row" style="margin-top: 12rpx;">
      <picker mode="selector" range="{{repeatOptions}}" range-key="label" value="{{repeatIndex}}" bindchange="onRepeatChange">
        <view class="input">频率：{{repeatOptions[repeatIndex].label}}</view>
      </picker>
      <input class="input" style="width: 180rpx;" type="number" value="{{form.repeat_interval}}" data-field="repeat_interval" bindinput="onInputChange" />
    </view>
  </view>

  <view class="section card">
    <view class="title">子任务</view>
    <view class="row" style="margin-top: 12rpx;">
      <input class="input" placeholder="新增子任务" value="{{newSubtaskTitle}}" bindinput="onSubtaskInput" />
      <button class="btn" bindtap="addSubtask">添加</button>
    </view>
    <view class="list-item" wx:for="{{subtasks}}" wx:key="id">
      <view class="row">
        <view>{{item.title}}</view>
        <view>
          <switch checked="{{item.is_completed}}" data-id="{{item.id}}" bindchange="toggleSubtask" />
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="removeSubtask">删除</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="title">附件</view>
    <button class="btn" bindtap="chooseAttachment">上传图片</button>
    <view class="list-item" wx:for="{{attachments}}" wx:key="id">
      <view class="row">
        <view>{{item.file_name}}</view>
        <view>
          <button size="mini" class="btn--ghost" data-url="{{item.cos_url}}" bindtap="previewAttachment">预览</button>
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="removeAttachment">删除</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="title">提醒</view>
    <view class="subtitle">提前 5/15/60/1440 分钟</view>
    <checkbox-group bindchange="onOffsetChange" class="row" style="margin-top: 12rpx; flex-wrap: wrap;">
      <label wx:for="{{reminderOffsets}}" wx:key="value" style="margin-right: 12rpx;">
        <checkbox value="{{item.value}}" checked="{{item.checked}}" /> {{item.label}}
      </label>
    </checkbox-group>
    <button class="btn" bindtap="createOffsetsReminder" style="margin-top: 12rpx;">创建提醒</button>
    <view class="list-item" wx:for="{{reminders}}" wx:key="id">
      <view class="row">
        <view>{{item.remind_at}}</view>
        <view>
          <view class="subtitle">{{item.is_sent ? '已发送' : '待发送'}}</view>
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="snoozeReminder">延后10分钟</button>
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="removeReminder">删除</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <button class="btn" bindtap="saveTask">保存任务</button>
    <button class="btn--ghost" style="margin-top: 12rpx;" bindtap="removeTask" wx:if="{{mode === 'edit'}}">删除任务</button>
  </view>
</view>
