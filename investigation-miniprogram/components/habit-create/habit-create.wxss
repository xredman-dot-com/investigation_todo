/* components/habit-create/habit-create.wxss */
.habit-create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 3000;
}

.habit-create-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 640rpx;
  background-color: var(--surface-color);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-secondary);
}

.modal-body {
  padding: 32rpx;
  max-height: 800rpx;
  overflow-y: auto;
}

.form-field {
  margin-bottom: 32rpx;
}

.field-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.field-input {
  width: 100%;
  padding: 24rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-color);
}

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-item {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.icon-item.active {
  border-color: var(--primary-color);
  background-color: rgba(59, 130, 246, 0.1);
}

.frequency-options {
  display: flex;
  gap: 16rpx;
}

.freq-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.freq-option.active {
  border-color: var(--primary-color);
  background-color: rgba(59, 130, 246, 0.1);
}

.freq-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.freq-label {
  font-size: 24rpx;
  color: var(--text-color);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: var(--text-secondary);
  border-right: 1rpx solid var(--border-color);
}

.modal-btn.confirm {
  color: var(--primary-color);
}

.modal-btn.disabled {
  color: var(--text-secondary);
  opacity: 0.5;
}
