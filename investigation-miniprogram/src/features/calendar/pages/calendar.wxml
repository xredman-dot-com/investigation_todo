<!-- pages/calendar/calendar.wxml -->
<!-- 参考滴答清单设计：日/周/月三视图 -->
<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="loadCalendarData" />
  <status-banner message="正在加载..." wx:if="{{isLoading}}" />
  
  <!-- 顶部导航栏 -->
  <view class="calendar-header">
    <view class="calendar-top">
      <global-menu inline="{{true}}" context="calendar" />
      <view class="calendar-title">日历</view>
    </view>
    <!-- 视图切换 Tab -->
    <view class="view-tabs">
      <view class="tab-item {{viewMode === 'month' ? 'active' : ''}}" 
            bindtap="onViewModeChange" 
            data-mode="month">月</view>
      <view class="tab-item {{viewMode === 'week' ? 'active' : ''}}" 
            bindtap="onViewModeChange" 
            data-mode="week">周</view>
      <view class="tab-item {{viewMode === 'day' ? 'active' : ''}}" 
            bindtap="onViewModeChange" 
            data-mode="day">日</view>
    </view>
    
    <!-- 日期导航 -->
    <view class="date-nav">
      <view class="nav-btn" bindtap="onPrevPage">‹</view>
      <view class="current-date-title">
        <block wx:if="{{viewMode === 'month'}}">{{currentMonthTitle}}</block>
        <block wx:if="{{viewMode === 'week'}}">{{weekRangeTitle}}</block>
        <block wx:if="{{viewMode === 'day'}}">{{currentMonthTitle}}</block>
      </view>
      <view class="nav-btn" bindtap="onNextPage">›</view>
    </view>
    <view class="lunar-title" wx:if="{{viewMode === 'day'}}">{{selectedDateLunar}}</view>
    
    <!-- 今天按钮 -->
    <view class="today-btn" bindtap="onGoToday">今天</view>
  </view>

  <!-- 星期标题栏 -->
  <view class="weekday-header" wx:if="{{viewMode !== 'day'}}">
    <view class="weekday-item" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 月视图 -->
  <view class="month-view" wx:if="{{viewMode === 'month'}}">
    <view class="month-week" wx:for="{{monthDays}}" wx:key="weekIndex" wx:for-index="weekIndex">
      <view class="month-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.fullDate === selectedDateStr ? 'selected' : ''}}"
            wx:for="{{item}}" 
            wx:key="fullDate"
            bindtap="onDayTap"
            data-full-date="{{item.fullDate}}">
        <view class="day-number">{{item.date}}</view>
        <view class="lunar-text">{{item.lunarText}}</view>
        <!-- 任务点 -->
        <view class="task-dots" wx:if="{{item.tasks.length > 0}}">
          <view class="task-dot priority-{{task.priority}}" wx:for="{{item.tasks.slice(0, 4)}}" wx:for-item="task" wx:key="id"></view>
        </view>
        <!-- 任务数量 -->
        <view class="task-count" wx:if="{{item.tasks.length > 0}}">{{item.tasks.length}}</view>
      </view>
    </view>
  </view>

  <!-- 周视图 -->
  <view class="week-view" wx:if="{{viewMode === 'week'}}">
    <view class="week-days">
      <view class="week-day {{item.isToday ? 'today' : ''}} {{item.fullDate === selectedDateStr ? 'selected' : ''}}"
            wx:for="{{weekDaysList}}" 
            wx:key="fullDate"
            bindtap="onDayTap"
            data-full-date="{{item.fullDate}}">
        <view class="week-day-header">
          <view class="week-day-number">{{item.date}}</view>
          <view class="week-day-week">{{weekDays[index]}}</view>
          <view class="week-day-lunar">{{item.lunarText}}</view>
        </view>
        <view class="week-day-tasks">
          <view class="week-task-item priority-{{task.priority}}" 
                wx:for="{{item.tasks}}" 
                wx:for-item="task" 
                wx:key="id"
                bindtap="onTaskTap"
                data-task-id="{{task.id}}">
            <view class="task-time" wx:if="{{task.due_time}}">{{task.due_time}}</view>
            <view class="task-title">{{task.title}}</view>
          </view>
          <view class="week-task-empty" wx:if="{{item.tasks.length === 0}}">无任务</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 日视图 -->
  <view class="day-view" wx:if="{{viewMode === 'day'}}">
    <!-- 全天任务 -->
    <view class="day-all-day">
      <view class="all-day-label">全天</view>
      <view class="all-day-tasks">
        <view class="all-day-task" 
              wx:for="{{dayAllDayTasks}}" 
              wx:for-item="task" 
              wx:key="id"
              bindtap="onTaskTap"
              data-task-id="{{task.id}}">
          <view class="task-priority-dot priority-{{task.priority}}"></view>
          <view class="task-title">{{task.title}}</view>
        </view>
        <view class="all-day-empty" wx:if="{{dayAllDayTasks.length === 0}}">无全天任务</view>
      </view>
    </view>
    
    <!-- 时间轴 -->
    <view class="day-timeline">
      <view class="time-slot" wx:for="{{timeSlots}}" wx:key="*this">
        <view class="time-label">{{item < 10 ? '0' + item : item}}:00</view>
        <view class="time-content">
          <view class="time-task" 
                wx:for="{{dayTimedTasksByHour[item]}}" 
                wx:for-item="task" 
                wx:key="id"
                bindtap="onTaskTap"
                data-task-id="{{task.id}}">
            <view class="task-priority-dot priority-{{task.priority}}"></view>
            <view class="task-title">{{task.title}}</view>
            <view class="task-time">{{task.due_time}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部选中日期任务列表 -->
  <view class="selected-tasks-panel" wx:if="{{viewMode === 'month' || viewMode === 'week'}}">
    <view class="panel-header">
      <view class="panel-title">{{selectedDateTitle}} · {{selectedDateLunar}} ({{selectedDateTasks.length}}个任务)</view>
      <view class="add-btn" bindtap="onAddTask">+ 添加</view>
    </view>
    <scroll-view class="task-list" scroll-y>
      <view class="task-item" 
            wx:for="{{selectedDateTasks}}" 
            wx:key="id"
            bindtap="onTaskTap"
            data-task-id="{{item.id}}">
        <view class="task-priority priority-{{item.priority}}"></view>
        <view class="task-content">
          <view class="task-title">{{item.title}}</view>
          <view class="task-meta">
            <text wx:if="{{item.due_time}}">⏰ {{item.due_time}}</text>
            <text wx:if="{{item.list_name}}">📋 {{item.list_name}}</text>
            <text wx:if="{{item.tags && item.tags.length}}">🏷️ {{item.tags.join(', ')}}</text>
          </view>
        </view>
        <view class="task-status {{item.status}}">{{item.status === 'done' ? '✓' : ''}}</view>
      </view>
      <view class="empty-state" wx:if="{{selectedDateTasks.length === 0}}">
        <view class="empty-text">该日期暂无任务</view>
        <view class="empty-hint">点击右上角添加任务</view>
      </view>
    </scroll-view>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bindtap="onAddTask">
    <text class="fab-icon">+</text>
  </view>

</view>
