.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 80% 10%, rgba(255, 157, 43, 0.16), transparent 50%),
    var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 40rpx;
}

.focus-header {
  margin-bottom: 16rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.mode-switch {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-accent);
  background: rgba(255, 157, 43, 0.14);
  border: 1rpx solid rgba(255, 157, 43, 0.22);
}

.header-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.timer-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 24rpx 40rpx rgba(0, 0, 0, 0.2);
}

.timer-ring {
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 40% 30%, rgba(255, 157, 43, 0.18), transparent 60%);
}

.timer-ring.running {
  border-color: rgba(255, 157, 43, 0.6);
  box-shadow: 0 0 24rpx rgba(255, 157, 43, 0.35);
}

.timer-time {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.timer-status {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.timer-phase {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.task-card,
.timer-summary {
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
}

.task-card {
  margin-bottom: 20rpx;
}

.task-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
}

.task-title.is-empty {
  color: var(--color-text-muted);
  font-weight: 400;
}

.timer-summary {
  margin-bottom: 24rpx;
}

.summary-line {
  font-size: 23rpx;
  color: var(--color-text-muted);
}

.summary-line + .summary-line {
  margin-top: 8rpx;
}

.btn {
  width: 100%;
  height: 84rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: var(--color-on-accent);
  font-weight: 600;
}

.btn::after {
  border: none;
}

.secondary-action {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-muted);
}
