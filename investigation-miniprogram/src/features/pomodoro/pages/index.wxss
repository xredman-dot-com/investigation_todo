/* Pomodoro page styles */
.page {
  min-height: 100vh;
  background: radial-gradient(circle at 80% 10%, rgba(255, 157, 43, 0.18), transparent 55%), var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 40rpx;
}

.focus-header {
  margin-bottom: 24rpx;
}

.focus-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.mode-tabs {
  display: flex;
  gap: 16rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: var(--color-surface-strong);
  color: var(--color-text-muted);
  font-size: 26rpx;
  border: 1rpx solid transparent;
}

.mode-tab.active {
  background: linear-gradient(135deg, rgba(255, 157, 43, 0.9), rgba(255, 199, 88, 0.9));
  color: #1a1205;
  border-color: rgba(255, 255, 255, 0.2);
  font-weight: 600;
}

.mini-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid var(--color-border);
}

.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.mini-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.mini-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-top: 6rpx;
}

.mini-divider {
  width: 1rpx;
  height: 36rpx;
  background: var(--color-border);
}

.timer-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 24rpx 40rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 28rpx;
}

.timer-ring {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.12);
  margin: 0 auto 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 40% 30%, rgba(255, 157, 43, 0.2), transparent 60%);
}

.timer-ring.running {
  border-color: rgba(255, 157, 43, 0.6);
  box-shadow: 0 0 24rpx rgba(255, 157, 43, 0.35);
}

.timer-time {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.timer-status {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.timer-phase {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.task-card {
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
  margin-bottom: 24rpx;
}

.task-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
}

.task-title.is-empty {
  color: var(--color-text-muted);
  font-weight: 400;
}

.preset-group {
  margin-bottom: 24rpx;
}

.preset-title {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin: 12rpx 0;
}

.preset-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  min-width: 72rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.04);
  color: var(--color-text);
  text-align: center;
  font-size: 24rpx;
}

.chip.active {
  background: rgba(255, 157, 43, 0.2);
  border-color: var(--color-accent);
  color: var(--color-accent);
  font-weight: 600;
}

.controls {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn::after {
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: var(--color-on-accent);
  font-weight: 600;
}

.btn.ghost {
  background: transparent;
  border: 1rpx solid var(--color-border);
  color: var(--color-text);
}

.stats-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

.stats-grid {
  display: flex;
  gap: 12rpx;
}

.stat-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 16rpx;
  background: var(--color-surface-strong);
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-accent);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.history-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 24rpx;
}

.history-title {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx;
  border-radius: 16rpx;
  background: var(--color-surface-strong);
}

.history-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.history-type {
  font-size: 28rpx;
  font-weight: 600;
}

.history-task {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.history-right {
  text-align: right;
}

.history-duration {
  font-size: 26rpx;
  font-weight: 600;
}

.history-status {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}
