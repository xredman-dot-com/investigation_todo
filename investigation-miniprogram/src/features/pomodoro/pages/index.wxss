/* Pomodoro page styles */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-text);
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  color: var(--color-text);
  font-size: 28rpx;
}

.btn {
  height: 72rpx;
  padding: 0 32rpx;
  background: var(--color-accent);
  color: #000;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn--ghost {
  height: 72rpx;
  padding: 0 32rpx;
  background: transparent;
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.list-item:last-child {
  border-bottom: none;
}

.empty-state {
  margin-top: 32rpx;
  padding: 48rpx;
  text-align: center;
  background: var(--color-surface-strong);
  border-radius: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
