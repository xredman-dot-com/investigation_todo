<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="fetchSessions" />

  <view class="focus-header">
    <view class="header-row">
      <view class="header-title">专注</view>
      <view class="mode-switch" bindtap="onSwitchMode">{{viewMode === 'pomodoro' ? '正计时' : '番茄钟'}}</view>
    </view>
    <view class="header-subtitle">{{todayStats.focusMinutes}} 分钟 · {{todayStats.focusCount}} 次完成</view>
  </view>

  <view class="timer-card">
    <view class="timer-ring {{timerRunning ? 'running' : ''}}">
      <view class="timer-time">{{displayTime}}</view>
      <view class="timer-status">{{timerStatusText}}</view>
      <view class="timer-phase">{{timerPhaseText}}</view>
    </view>

    <view class="task-card" bindtap="onShowTaskSelector">
      <view class="task-label">当前任务</view>
      <view class="task-title {{currentTask ? '' : 'is-empty'}}">{{currentTask ? currentTask.title : '不选任务也可以开始'}}</view>
    </view>

    <view class="timer-summary" wx:if="{{viewMode === 'pomodoro'}}">
      <view class="summary-line">默认 {{focusMinutes}} 分钟专注</view>
      <view class="summary-line">结束后自动进入 {{breakMinutes}} 分钟休息</view>
    </view>

    <view class="timer-summary" wx:else>
      <view class="summary-line">正计时适合开放时长的深度工作</view>
      <view class="summary-line">开始后会持续累计直到你主动结束</view>
    </view>

    <view class="controls">
      <button class="btn primary" bindtap="onPrimaryAction">{{primaryLabel}}</button>
    </view>

    <view class="secondary-action" wx:if="{{currentSessionId}}" bindtap="onSecondaryAction">
      {{timerRunning ? '暂停本次专注' : '结束本次专注'}}
    </view>
  </view>

  <task-selector
    visible="{{showTaskSelector}}"
    selectedTaskId="{{currentTask ? currentTask.id : ''}}"
    bind:confirm="onTaskConfirm"
    bind:cancel="onTaskCancel"
  />
</view>
