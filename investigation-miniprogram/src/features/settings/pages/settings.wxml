<!-- pages/settings/settings.wxml -->
<view class="page" style="{{themeStyle}}">
  <!-- 用户信息卡片 -->
  <view class="profile-card card">
    <view class="profile-avatar">👤</view>
    <view class="profile-info">
      <view class="profile-name">{{userInfo.name || '未登录'}}</view>
      <view class="profile-email">{{userInfo.email || '点击登录账号'}}</view>
    </view>
    <view class="profile-action">
      <text>›</text>
    </view>
  </view>

  <!-- 主题设置 -->
  <view class="section-title">主题设置</view>
  <view class="settings-card card">
    <view class="theme-grid">
      <view 
        wx:for="{{themeList}}" 
        wx:key="name"
        class="theme-item {{currentTheme === item.name ? 'active' : ''}}" 
        bindtap="onThemeChange" 
        data-theme="{{item.name}}"
      >
        <view class="theme-preview theme-preview-{{item.class}}"></view>
        <view class="theme-name">{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section-title">通用设置</view>
  <view class="settings-card card">
    <view class="setting-item" bindtap="onSetting" data-index="{{0}}">
      <view class="setting-left">
        <text class="setting-icon">🔔</text>
        <text class="setting-label">提醒设置</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onSetting">
      <view class="setting-left">
        <text class="setting-icon">🌙</text>
        <text class="setting-label">深色模式</text>
      </view>
      <switch checked="{{darkMode}}" bindchange="onDarkModeChange" color="var(--color-accent)" />
    </view>
    <view class="setting-item" bindtap="onSetting" data-index="{{2}}">
      <view class="setting-left">
        <text class="setting-icon">📅</text>
        <text class="setting-label">日历设置</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onSetting" data-index="{{1}}">
      <view class="setting-left">
        <text class="setting-icon">🍅</text>
        <text class="setting-label">番茄钟设置</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onGoHabits">
      <view class="setting-left">
        <text class="setting-icon">✅</text>
        <text class="setting-label">习惯打卡</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section-title">数据管理</view>
  <view class="settings-card card">
    <view class="setting-item" bindtap="onBackup">
      <view class="setting-left">
        <text class="setting-icon">☁️</text>
        <text class="setting-label">备份数据</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onSync">
      <view class="setting-left">
        <text class="setting-icon">🔄</text>
        <text class="setting-label">同步设置</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item danger" bindtap="onClearCache">
      <view class="setting-left">
        <text class="setting-icon">🗑️</text>
        <text class="setting-label">清除缓存</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section-title">关于</view>
  <view class="settings-card card">
    <view class="setting-item" bindtap="onAbout">
      <view class="setting-left">
        <text class="setting-icon">ℹ️</text>
        <text class="setting-label">关于格物清单</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onFeedback">
      <view class="setting-left">
        <text class="setting-icon">💬</text>
        <text class="setting-label">反馈建议</text>
      </view>
      <text class="setting-arrow">›</text>
    </view>
  </view>
</view>
