/* pages/settings/notification/notification.wxss */
.page {
  min-height: 100vh;
  background-color: var(--background-color);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: var(--surface-color);
  border-bottom: 1rpx solid var(--border-color);
}

.nav-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-color);
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.content {
  flex: 1;
  padding: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin: 32rpx 24rpx 16rpx;
  padding-left: 8rpx;
}

.settings-card {
  margin: 0 24rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  flex: 1;
}

.setting-label {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.setting-value {
  font-size: 28rpx;
  color: var(--primary-color);
}

.hint {
  margin: 32rpx 24rpx;
  padding: 24rpx;
  background-color: rgba(59, 130, 246, 0.05);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}
