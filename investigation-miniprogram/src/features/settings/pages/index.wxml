<view class="container">
  <view class="section card">
    <view class="title">账户信息</view>
    <view class="subtitle">{{user ? (user.nickname || '未设置昵称') : '未设置昵称'}}</view>
    <view class="subtitle">ID: {{user ? user.id : ''}}</view>
  </view>

  <view class="section card">
    <view class="title">清单管理</view>
    <view class="row" style="margin-top: 12rpx;">
      <input class="input" placeholder="新清单名称" value="{{newListName}}" bindinput="onNewListInput" />
      <button class="btn" bindtap="addList">添加</button>
    </view>
    <view class="list-item" wx:for="{{lists}}" wx:key="id">
      <view class="row">
        <input class="input" style="flex: 1;" value="{{editNames[item.id]}}" data-id="{{item.id}}" bindinput="onEditNameInput" />
        <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="saveList">保存</button>
        <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="removeList">删除</button>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="title">数据导出</view>
    <button class="btn" bindtap="runExport">导出并复制</button>
    <textarea class="input" style="margin-top: 12rpx; height: 200rpx;" value="{{exportText}}"></textarea>
  </view>

  <view class="section card">
    <view class="title">提醒投递日志</view>
    <button class="btn" bindtap="runDispatch">触发投递</button>
    <view class="list-item" wx:for="{{reminderLogs}}" wx:key="id">
      <view class="row">
        <view>{{item.created_at}}</view>
        <view class="subtitle">{{item.status}}</view>
      </view>
    </view>
  </view>
</view>
