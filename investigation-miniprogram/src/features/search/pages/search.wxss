/* pages/search/search.wxss */
.page {
  min-height: 100vh;
  background-color: var(--background-color);
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 24rpx;
  background-color: var(--surface-color);
  border-bottom: 1rpx solid var(--border-color);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
}

.search-icon {
  font-size: 36rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-secondary);
  opacity: 0;
  pointer-events: none;
}

.clear-btn.show {
  opacity: 1;
  pointer-events: auto;
}

.filter-tabs {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: var(--surface-color);
}

.filter-tab {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  background-color: var(--background-color);
}

.filter-tab.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

.results {
  flex: 1;
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.result-list,
.list-result-list {
  background-color: var(--surface-color);
  border-radius: 16rpx;
  overflow: hidden;
}

.list-result-list {
  margin-bottom: 24rpx;
}

.list-result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.list-result-item:last-child {
  border-bottom: none;
}

.list-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.list-info {
  flex: 1;
}

.list-name {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 4rpx;
}

.list-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tag-result-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tag-result-item {
  padding: 12rpx 24rpx;
  background-color: var(--background-color);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--primary-color);
}

.history-section {
  padding: 32rpx 24rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
}

.clear-history {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 8rpx 16rpx;
}

.history-list {
  background-color: var(--surface-color);
  border-radius: 16rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
}

.history-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}
