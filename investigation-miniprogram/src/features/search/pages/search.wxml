<!-- pages/search/search.wxml -->
<view class="page" style="{{themeStyle}}">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        value="{{searchText}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        placeholder="搜索任务、清单、标签..."
        confirm-type="search"
        focus="{{true}}"
      />
      <view class="clear-btn {{searchText ? 'show' : ''}}" bindtap="onClear">
        ×
      </view>
    </view>
  </view>

  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="onRetrySearch" />
  <status-banner message="正在搜索..." wx:if="{{isLoading}}" />

  <!-- 搜索筛选 -->
  <view class="filter-tabs" wx:if="{{searchText}}">
    <view
      class="filter-tab {{filterType === 'all' ? 'active' : ''}}"
      bindtap="onFilterChange"
      data-type="all"
    >
      全部
    </view>
    <view
      class="filter-tab {{filterType === 'tasks' ? 'active' : ''}}"
      bindtap="onFilterChange"
      data-type="tasks"
    >
      任务
    </view>
    <view
      class="filter-tab {{filterType === 'lists' ? 'active' : ''}}"
      bindtap="onFilterChange"
      data-type="lists"
    >
      清单
    </view>
    <view
      class="filter-tab {{filterType === 'tags' ? 'active' : ''}}"
      bindtap="onFilterChange"
      data-type="tags"
    >
      标签
    </view>
  </view>

  <!-- 搜索结果 -->
  <scroll-view class="results" scroll-y wx:if="{{searchText}}">
    <!-- 任务结果 -->
    <view class="section" wx:if="{{filterType === 'all' || filterType === 'tasks'}}">
      <view class="section-title" wx:if="{{taskResults.length > 0}}">
        找到 {{taskResults.length}} 个任务
      </view>
      <view class="result-list" wx:if="{{taskResults.length > 0}}">
        <task-card
          wx:for="{{taskResults}}"
          wx:key="id"
          task="{{item}}"
          bind:toggle="onTaskToggle"
          bind:detail="onTaskDetail"
        />
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">📋</text>
        <text class="empty-text">未找到相关任务</text>
      </view>
    </view>

    <!-- 清单结果 -->
    <view class="section" wx:if="{{filterType === 'all' || filterType === 'lists'}}">
      <view class="section-title" wx:if="{{listResults.length > 0}}">
        找到 {{listResults.length}} 个清单
      </view>
      <view class="list-result-list" wx:if="{{listResults.length > 0}}">
        <view
          class="list-result-item"
          wx:for="{{listResults}}"
          wx:key="id"
          bindtap="onSelectList"
          data-list="{{item}}"
        >
          <text class="list-icon">{{item.icon || '📁'}}</text>
          <view class="list-info">
            <view class="list-name">{{item.name}}</view>
            <view class="list-count">{{item.task_count || 0}} 个任务</view>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">📁</text>
        <text class="empty-text">未找到相关清单</text>
      </view>
    </view>

    <!-- 标签结果 -->
    <view class="section" wx:if="{{filterType === 'all' || filterType === 'tags'}}">
      <view class="section-title" wx:if="{{tagResults.length > 0}}">
        找到 {{tagResults.length}} 个标签
      </view>
      <view class="tag-result-list" wx:if="{{tagResults.length > 0}}">
        <view
          class="tag-result-item"
          wx:for="{{tagResults}}"
          wx:key="*this"
          bindtap="onSelectTag"
          data-tag="{{item}}"
        >
          #{{item}}
        </view>
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">🏷️</text>
        <text class="empty-text">未找到相关标签</text>
      </view>
    </view>
  </scroll-view>

  <!-- 搜索历史 -->
  <view class="history-section" wx:if="{{!searchText && searchHistory.length > 0}}">
    <view class="history-header">
      <view class="history-title">搜索历史</view>
      <view class="clear-history" bindtap="onClearHistory">清除</view>
    </view>
    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{searchHistory}}"
        wx:key="*this"
        bindtap="onHistoryClick"
        data-query="{{item}}"
      >
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!searchText && searchHistory.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">搜索任务、清单、标签</text>
    <text class="empty-hint">输入关键词开始搜索</text>
  </view>
</view>
