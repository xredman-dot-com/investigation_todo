<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="fetchItems" />
  <status-banner message="正在加载倒数日..." wx:if="{{isLoading}}" />
  <view class="header">
    <view class="header-row">
      <global-menu inline="{{true}}" />
      <view class="title">倒数日</view>
    </view>
    <view class="subtitle">把重要的日子放在前面</view>
  </view>

  <view class="summary-strip">
    <view class="summary-item">
      <view class="summary-label">总数</view>
      <view class="summary-value">{{summary.total}}</view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-label">进行中</view>
      <view class="summary-value">{{summary.upcoming}}</view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-label">已过</view>
      <view class="summary-value">{{summary.passed}}</view>
    </view>
  </view>

  <view class="next-card">
    <view class="next-label">最近的倒数日</view>
    <view class="next-main">
      <view class="next-title">{{summary.nextTitle}}</view>
      <view class="next-days">{{summary.nextDays}} 天</view>
    </view>
  </view>

  <view class="list-section">
    <view class="section-title">我的倒数日</view>
    <view class="countdown-list">
      <view class="countdown-card {{item.toneClass}}" wx:for="{{items}}" wx:key="id">
        <view class="card-main">
          <view class="card-title">{{item.title}}</view>
          <view class="card-date">{{item.displayDate}}</view>
          <view class="card-tags">
            <view class="tag {{item.typeClass}}">{{item.typeLabel}}</view>
            <view class="tag ghost">{{item.calendarLabel}}</view>
          </view>
          <view class="card-badge">{{item.badgeText}}</view>
        </view>
        <view class="card-right">
          <view class="day-number">{{item.dayNumber}}</view>
          <view class="day-label">天</view>
          <button size="mini" class="btn mini ghost" data-id="{{item.id}}" bindtap="removeItem">删除</button>
        </view>
      </view>
    </view>
    <view wx:if="{{items.length === 0}}" class="empty-state">
      <view class="empty-text">暂无倒数日</view>
      <view class="empty-hint">添加一个重要日期开始吧</view>
    </view>
  </view>

  <view class="fab" bindtap="openForm">
    <text class="fab-icon">+</text>
  </view>

  <view class="modal-mask" wx:if="{{showForm}}" bindtap="closeForm"></view>
  <view class="modal-sheet {{showForm ? 'open' : ''}}">
    <view class="sheet-header">
      <view class="sheet-title">新增倒数日</view>
      <view class="sheet-close" bindtap="closeForm">×</view>
    </view>
    <view class="sheet-body">
      <view class="chip-row">
        <view class="chip {{form.type === 'birthday' ? 'active' : ''}}" data-value="birthday" bindtap="onTypeSelect">生日</view>
        <view class="chip {{form.type === 'anniversary' ? 'active' : ''}}" data-value="anniversary" bindtap="onTypeSelect">纪念日</view>
        <view class="chip {{form.type === 'countdown' ? 'active' : ''}}" data-value="countdown" bindtap="onTypeSelect">倒数日</view>
        <view class="chip {{form.type === 'festival' ? 'active' : ''}}" data-value="festival" bindtap="onTypeSelect">节日</view>
      </view>
      <view class="chip-row">
        <view class="chip {{form.calendarType === 'solar' ? 'active' : ''}}" data-value="solar" bindtap="onCalendarSelect">公历</view>
        <view class="chip {{form.calendarType === 'lunar' ? 'active' : ''}}" data-value="lunar" bindtap="onCalendarSelect">农历</view>
      </view>
      <input class="input" placeholder="例如：毕业 / 旅行" value="{{form.title}}" bindinput="onTitleInput" />
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="date-picker {{form.date ? '' : 'placeholder'}}">
          {{form.date ? form.date : (form.calendarType === 'lunar' ? '选择农历日期' : '选择公历日期')}}
        </view>
      </picker>
      <button class="btn primary" bindtap="addItem">添加</button>
    </view>
  </view>
</view>
