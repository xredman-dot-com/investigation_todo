/* Countdown page styles */
.page {
  min-height: 100vh;
  background: radial-gradient(circle at 80% 0%, rgba(255, 157, 43, 0.14), transparent 60%), var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 48rpx;
}

.header {
  margin-bottom: 20rpx;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.summary-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.04);
  margin-bottom: 16rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.summary-value {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.summary-divider {
  width: 1rpx;
  height: 36rpx;
  background: var(--color-border);
}

.next-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.next-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.next-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.next-title {
  font-size: 30rpx;
  font-weight: 600;
}

.next-days {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-accent);
}

.input {
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  color: var(--color-text);
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.date-picker {
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
  font-size: 28rpx;
  color: var(--color-text);
}

.date-picker.placeholder {
  color: var(--color-text-muted);
}

.btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn::after {
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: #101010;
  font-weight: 600;
}

.btn.ghost {
  background: transparent;
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
}

.btn.mini {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.list-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.countdown-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.countdown-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border);
  background: var(--color-surface);
}

.countdown-card.upcoming {
  background: linear-gradient(150deg, rgba(255, 157, 43, 0.1), rgba(255, 255, 255, 0.02));
}

.countdown-card.passed {
  background: linear-gradient(150deg, rgba(120, 120, 120, 0.12), rgba(255, 255, 255, 0.02));
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.card-date {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.card-badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  font-size: 22rpx;
  color: var(--color-text);
}

.card-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  color: var(--color-text);
}

.tag.ghost {
  background: transparent;
  border: 1rpx solid var(--color-border);
  color: var(--color-text-muted);
}

.tag.type-birthday {
  background: rgba(255, 157, 43, 0.18);
  color: var(--color-accent);
}

.tag.type-anniversary {
  background: rgba(255, 101, 155, 0.18);
  color: #ff65a0;
}

.tag.type-countdown {
  background: rgba(88, 160, 255, 0.18);
  color: #58a0ff;
}

.tag.type-festival {
  background: rgba(80, 200, 140, 0.18);
  color: #50c88c;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.day-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.day-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.empty-state {
  margin-top: 16rpx;
  padding: 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 1000;
}

.fab-icon {
  font-size: 56rpx;
  color: #ffffff;
  line-height: 1;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1100;
}

.modal-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 24rpx;
  transform: translateY(100%);
  transition: transform 0.25s ease;
  z-index: 1200;
}

.modal-sheet.open {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 600;
}

.sheet-close {
  font-size: 32rpx;
  color: var(--color-text-muted);
}

.sheet-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.04);
  font-size: 22rpx;
  color: var(--color-text);
}

.chip.active {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: rgba(255, 157, 43, 0.16);
  font-weight: 600;
}
