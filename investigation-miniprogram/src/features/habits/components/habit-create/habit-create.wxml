<!-- components/habit-create/habit-create.wxml -->
<view class="habit-create-modal {{visible ? 'show' : ''}}" bindtap="onCancel">
  <view class="modal-content" catchtap="onStopPropagation">
    <view class="modal-header">
      <view class="modal-title">创建新习惯</view>
      <view class="modal-close" bindtap="onCancel">×</view>
    </view>

    <view class="modal-body">
      <view class="form-field">
        <view class="field-label">习惯名称</view>
        <input class="field-input" value="{{name}}" bindinput="onNameInput" placeholder="例如：早起、运动、阅读" />
      </view>

      <view class="form-field">
        <view class="field-label">选择图标</view>
        <view class="icon-grid">
          <view
            class="icon-item {{selectedIcon === item ? 'active' : ''}}"
            wx:for="{{icons}}"
            wx:key="*this"
            bindtap="onSelectIcon"
            data-icon="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-field">
        <view class="field-label">目标频率</view>
        <view class="frequency-options">
          <view
            class="freq-option {{frequency === 'daily' ? 'active' : ''}}"
            bindtap="onSelectFrequency"
            data-freq="daily"
          >
            <view class="freq-icon">📅</view>
            <view class="freq-label">每天</view>
          </view>
          <view
            class="freq-option {{frequency === 'weekly' ? 'active' : ''}}"
            bindtap="onSelectFrequency"
            data-freq="weekly"
          >
            <view class="freq-icon">📆</view>
            <view class="freq-label">每周</view>
          </view>
          <view
            class="freq-option {{frequency === 'monthly' ? 'active' : ''}}"
            bindtap="onSelectFrequency"
            data-freq="monthly"
          >
            <view class="freq-icon">🗓️</view>
            <view class="freq-label">每月</view>
          </view>
        </view>
      </view>

      <view class="form-field">
        <view class="field-label">提醒时间（可选）</view>
        <input class="field-input" value="{{reminder}}" bindinput="onReminderInput" placeholder="例如：08:00" />
      </view>
    </view>

    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="onCancel">取消</view>
      <view class="modal-btn confirm {{name ? '' : 'disabled'}}" bindtap="onConfirm">创建</view>
    </view>
  </view>
</view>
