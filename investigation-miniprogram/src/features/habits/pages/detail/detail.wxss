/* pages/habits/detail/detail.wxss */
.page {
  min-height: 100vh;
  background-color: var(--background-color);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: var(--surface-color);
  border-bottom: 1rpx solid var(--border-color);
}

.nav-btn {
  font-size: 32rpx;
  color: var(--primary-color);
  padding: 8rpx 16rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.content {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.habit-card {
  margin-bottom: 24rpx;
}

.habit-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.habit-icon-large {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background-color: var(--background-color);
  border-radius: 50%;
  margin-right: 24rpx;
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.habit-frequency {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.freq-label {
  color: var(--primary-color);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 24rpx;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.calendar-day {
  width: calc((100% - 60rpx) / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--background-color);
  border-radius: 12rpx;
  position: relative;
}

.calendar-day.checked {
  background-color: rgba(16, 185, 129, 0.1);
}

.day-number {
  font-size: 28rpx;
  color: var(--text-color);
}

.check-mark {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  font-size: 24rpx;
  color: var(--success-color);
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--background-color);
  border: 2rpx solid var(--border-color);
}

.legend-dot.checked {
  background-color: var(--success-color);
  border-color: var(--success-color);
}

.history-list {
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 28rpx;
  color: var(--text-color);
  flex: 1;
}

.history-time {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 24rpx;
}

.history-status {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.history-status.done {
  color: var(--success-color);
  background-color: rgba(16, 185, 129, 0.1);
}

.history-status.missed {
  color: var(--danger-color);
  background-color: rgba(239, 68, 68, 0.1);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.reminder-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reminder-icon {
  font-size: 40rpx;
}

.reminder-time {
  font-size: 28rpx;
  color: var(--text-color);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: var(--surface-color);
  border-top: 1rpx solid var(--border-color));
}

.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  background-color: var(--primary-color);
  border-radius: 12rpx;
  color: #FFFFFF;
}

.checkin-btn.checked {
  background-color: var(--success-color);
}

.checkin-icon {
  font-size: 32rpx;
}
