.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 157, 43, 0.18), transparent 32%),
    var(--color-bg);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.nav-btn {
  min-width: 88rpx;
  font-size: 28rpx;
  color: var(--color-accent);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
}

.content {
  flex: 1;
  padding: 0 24rpx 180rpx;
}

.hero-card,
.card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-status {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-accent);
}

.hero-meta {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 26rpx 18rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-title {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.calendar-day {
  width: calc((100% - 72rpx) / 7);
  height: 76rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface-strong);
  color: var(--color-text-muted);
  font-size: 24rpx;
}

.calendar-day.checked {
  background: rgba(44, 182, 125, 0.16);
  color: var(--color-success);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: var(--color-surface-strong);
}

.history-date,
.history-count {
  font-size: 24rpx;
}

.history-count {
  color: var(--color-text-muted);
}

.history-status {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.history-status.done {
  color: var(--color-success);
  background: rgba(44, 182, 125, 0.14);
}

.history-status.missed {
  color: var(--color-danger);
  background: rgba(255, 92, 92, 0.14);
}

.empty {
  padding: 24rpx 0 8rpx;
  text-align: center;
}

.empty-text,
.reminder-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.danger-card {
  margin-bottom: 0;
}

.danger-action {
  font-size: 26rpx;
  color: var(--color-danger);
}

.bottom-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 34rpx;
}

.checkin-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: var(--color-on-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: var(--shadow-fab);
}

.checkin-btn.checked {
  background: rgba(44, 182, 125, 0.16);
  color: var(--color-success);
  box-shadow: none;
}
