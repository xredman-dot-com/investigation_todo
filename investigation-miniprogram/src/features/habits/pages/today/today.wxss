.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  margin-left: 16rpx;
}

/* 习惯列表 */
.habit-list {
  padding-bottom: 160rpx;
}

.habit-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.habit-card.completed {
  background: rgba(76, 175, 80, 0.08);
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.habit-meta {
  font-size: 26rpx;
  color: #999;
}

.habit-card.completed .habit-name {
  color: #4caf50;
}

.habit-card.completed .habit-meta {
  color: #81c784;
}

/* 打卡按钮 */
.habit-action {
  margin-left: 24rpx;
}

.check-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.check-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4caf50;
  color: #fff;
  font-size: 48rpx;
  border-radius: 50%;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: -120rpx;
  top: 0;
  bottom: 0;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  transition: right 0.2s;
}

.habit-card:active .delete-btn {
  right: 0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 34rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 48rpx;
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 200;
}

.modal-content {
  width: 100%;
  padding: 40rpx;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 16rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  height: 96rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.form-input-small {
  width: 160rpx;
  display: inline-block;
}

.form-unit {
  margin-left: 16rpx;
  font-size: 30rpx;
  color: #666;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.loading {
  padding: 80rpx;
  text-align: center;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}
