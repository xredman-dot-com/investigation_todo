/* Habits page styles */
.page {
  min-height: 100vh;
  background: radial-gradient(circle at 20% 0%, rgba(255, 157, 43, 0.15), transparent 55%), var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 48rpx;
}

.habit-header {
  margin-bottom: 20rpx;
}

.habit-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.habit-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.habit-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.summary-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.04);
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.summary-value {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.summary-divider {
  width: 1rpx;
  height: 36rpx;
  background: var(--color-border);
}

.create-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.create-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.create-row {
  display: flex;
  gap: 16rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--color-surface-strong);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  color: var(--color-text);
  font-size: 28rpx;
}

.input-small {
  flex: 0 0 160rpx;
  text-align: center;
}

.create-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn::after {
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: var(--color-on-accent);
  font-weight: 600;
}

.btn.ghost {
  background: transparent;
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
}

.btn.mini {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.list-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.habit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.habit-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 18rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.habit-card.positive {
  background: linear-gradient(160deg, rgba(255, 157, 43, 0.08), rgba(255, 255, 255, 0.02));
}

.habit-card.negative {
  background: linear-gradient(160deg, rgba(80, 125, 255, 0.1), rgba(255, 255, 255, 0.02));
}

.habit-main {
  flex: 1;
  min-width: 0;
}

.habit-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.habit-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 10rpx;
}

.habit-reminder {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.habit-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.logs-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 24rpx;
}

.logs-subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: var(--color-surface-strong);
}

.log-date {
  font-size: 24rpx;
  color: var(--color-text);
}

.log-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.empty-state {
  margin-top: 16rpx;
  padding: 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
}

.empty-state.compact {
  padding: 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}
