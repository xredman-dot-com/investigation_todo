.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 157, 43, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 28%),
    var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 160rpx;
}

.habit-header {
  margin-bottom: 18rpx;
}

.habit-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.habit-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.section,
.completed-bar,
.empty-shell {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
}

.section {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-head.tap-target {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
}

.section-meta {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.habit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.habit-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid var(--color-border);
}

.habit-card-completed {
  background: rgba(255, 255, 255, 0.02);
}

.habit-main {
  flex: 1;
  min-width: 0;
}

.habit-name {
  font-size: 28rpx;
  font-weight: 600;
}

.habit-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.check-btn,
.done-badge {
  min-width: 132rpx;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  flex-shrink: 0;
}

.check-btn {
  margin: 0;
  padding: 0 28rpx;
  border: none;
  color: var(--color-on-accent);
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
}

.check-btn::after {
  border: none;
}

.done-badge {
  color: var(--color-success);
  background: rgba(44, 182, 125, 0.12);
}

.completed-section {
  padding-bottom: 20rpx;
}

.completed-bar {
  margin-bottom: 24rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.completed-label,
.completed-toggle {
  font-size: 24rpx;
}

.completed-toggle {
  color: var(--color-text-muted);
}

.empty-state,
.empty-shell {
  padding: 36rpx 24rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
}

.empty-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.fab {
  position: fixed;
  right: 24rpx;
  bottom: 42rpx;
  height: 92rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  color: var(--color-on-accent);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 10;
}
