<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="fetchHabits" />

  <view class="habit-header">
    <view class="habit-title">今日习惯</view>
    <view class="habit-subtitle">{{progress.completed}} / {{progress.total}} · {{progress.summary}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">今天要做</view>
      <view class="section-meta">{{pendingHabits.length}}</view>
    </view>

    <view class="habit-list" wx:if="{{pendingHabits.length > 0}}">
      <view class="habit-card" wx:for="{{pendingHabits}}" wx:key="id" bindtap="onGoDetail" data-id="{{item.id}}">
        <view class="habit-main">
          <view class="habit-name">{{item.name}}</view>
          <view class="habit-meta">{{item.statusText}}</view>
        </view>
        <button class="check-btn" catchtap="onCheckIn" data-id="{{item.id}}">打卡</button>
      </view>
    </view>

    <view wx:if="{{pendingHabits.length === 0 && !isLoading}}" class="empty-state">
      <view class="empty-text">今天没有待完成习惯</view>
      <view class="empty-hint">创建一个新习惯，或者看看已完成列表。</view>
    </view>
  </view>

  <view class="completed-bar" wx:if="{{completedHabits.length > 0}}" bindtap="onToggleCompleted">
    <view class="completed-label">已完成 {{completedHabits.length}} 个</view>
    <view class="completed-toggle">{{showCompleted ? "收起" : "展开"}}</view>
  </view>

  <view class="section completed-section" wx:if="{{completedHabits.length > 0 && showCompleted}}">
    <view class="section-head tap-target" bindtap="onToggleCompleted">
      <view class="section-title">已完成</view>
      <view class="section-meta">{{completedHabits.length}}</view>
    </view>

    <view class="habit-list">
      <view class="habit-card habit-card-completed" wx:for="{{completedHabits}}" wx:key="id" bindtap="onGoDetail" data-id="{{item.id}}">
        <view class="habit-main">
          <view class="habit-name">{{item.name}}</view>
          <view class="habit-meta">{{item.statusText}}</view>
        </view>
        <view class="done-badge">已完成</view>
      </view>
    </view>
  </view>

  <view wx:if="{{pendingHabits.length === 0 && completedHabits.length === 0 && !isLoading && !errorMessage}}" class="empty-shell">
    <view class="empty-text">还没有习惯</view>
    <view class="empty-hint">先添加一个，再回来打卡。</view>
  </view>

  <view class="fab" bindtap="onOpenCreate">+ 新习惯</view>

  <habit-create visible="{{showCreateModal}}" bind:confirm="onCreateHabit" bind:cancel="onCloseCreate" />
</view>
