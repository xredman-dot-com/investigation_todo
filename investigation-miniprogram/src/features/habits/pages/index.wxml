<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="fetchHabits" />
  <status-banner message="正在加载习惯..." wx:if="{{isLoading}}" />

  <view class="habit-header">
    <view class="habit-top">
      <global-menu inline="{{true}}" />
      <view class="habit-title">习惯</view>
    </view>
    <view class="habit-subtitle">让每日打卡更有仪式感</view>
  </view>

  <view class="summary-strip">
    <view class="summary-item">
      <view class="summary-label">习惯</view>
      <view class="summary-value">{{summary.total}}</view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-label">累计</view>
      <view class="summary-value">{{summary.totalCompleted}}</view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-label">最长</view>
      <view class="summary-value">{{summary.maxStreak}}</view>
    </view>
  </view>

  <view class="create-card">
    <view class="create-title">新增习惯</view>
    <view class="create-row">
      <input class="input" placeholder="习惯名称" value="{{form.name}}" data-field="name" bindinput="onInputChange" />
      <input class="input input-small" placeholder="次数" type="number" value="{{form.target_count}}" data-field="target_count" bindinput="onInputChange" />
    </view>
    <view class="create-actions">
      <button class="btn primary" bindtap="addHabit">添加</button>
    </view>
  </view>

  <view class="list-section">
    <view class="section-title">今日打卡</view>
    <view class="habit-list">
      <view class="habit-card {{item.toneClass}}" wx:for="{{habits}}" wx:key="id">
        <view class="habit-main">
          <view class="habit-name">{{item.name}}</view>
          <view class="habit-meta">
            <text>{{item.targetText}}</text>
            <text>连续 {{item.current_streak}} 天</text>
            <text>累计 {{item.total_completed}}</text>
          </view>
          <view class="habit-reminder">{{item.reminderText}}</view>
        </view>
        <view class="habit-actions">
          <button size="mini" class="btn mini primary" data-id="{{item.id}}" bindtap="checkInHabit">打卡</button>
          <button size="mini" class="btn mini ghost" data-id="{{item.id}}" bindtap="showLogs">记录</button>
          <button size="mini" class="btn mini ghost" data-id="{{item.id}}" bindtap="removeHabit">删除</button>
        </view>
      </view>
    </view>
    <view wx:if="{{habits.length === 0 && !isLoading && !errorMessage}}" class="empty-state">
      <view class="empty-text">暂无习惯</view>
      <view class="empty-hint">先添加一个习惯开始打卡</view>
    </view>
  </view>

  <view class="logs-card">
    <view class="section-title">打卡记录</view>
    <view class="logs-subtitle">{{activeHabitName ? activeHabitName : "请选择习惯查看记录"}}</view>
    <view class="log-list" wx:if="{{logs.length > 0}}">
      <view class="log-item" wx:for="{{logs}}" wx:key="id">
        <view class="log-date">{{item.completed_at}}</view>
        <view class="log-count">次数 {{item.count}}</view>
      </view>
    </view>
    <view wx:if="{{logs.length === 0}}" class="empty-state compact">
      <view class="empty-text">暂无记录</view>
      <view class="empty-hint">选择习惯后查看历史打卡</view>
    </view>
  </view>
</view>
