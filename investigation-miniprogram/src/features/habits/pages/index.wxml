<view class="container" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" actionText="重试" bind:action="fetchHabits" />
  <status-banner message="正在加载习惯..." wx:if="{{isLoading}}" />
  <view class="section card">
    <view class="title">新增习惯</view>
    <input class="input" style="margin-top: 12rpx;" placeholder="习惯名称" value="{{form.name}}" data-field="name" bindinput="onInputChange" />
    <input class="input" style="margin-top: 12rpx;" placeholder="目标次数" type="number" value="{{form.target_count}}" data-field="target_count" bindinput="onInputChange" />
    <button class="btn" style="margin-top: 12rpx;" bindtap="addHabit">添加习惯</button>
  </view>

  <view class="section card">
    <view class="title">习惯列表</view>
    <view class="list-item" wx:for="{{habits}}" wx:key="id">
      <view class="row">
        <view>
          <view>{{item.name}}</view>
          <view class="subtitle">连续 {{item.current_streak}} 天，累计 {{item.total_completed}}</view>
        </view>
        <view>
          <button size="mini" class="btn" data-id="{{item.id}}" bindtap="checkInHabit">打卡</button>
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="showLogs">日志</button>
          <button size="mini" class="btn--ghost" data-id="{{item.id}}" bindtap="removeHabit">删除</button>
        </view>
      </view>
    </view>
    <view wx:if="{{habits.length === 0 && !isLoading && !errorMessage}}" class="empty-state">
      <view class="empty-text">暂无习惯</view>
      <view class="empty-hint">先添加一个习惯开始打卡</view>
    </view>
  </view>

  <view class="section card">
    <view class="title">打卡记录</view>
    <view class="list-item" wx:for="{{logs}}" wx:key="id">
      <view class="row">
        <view>{{item.completed_at}}</view>
        <view class="subtitle">次数 {{item.count}}</view>
      </view>
    </view>
    <view wx:if="{{logs.length === 0}}" class="subtitle">请选择习惯查看记录</view>
  </view>
</view>
