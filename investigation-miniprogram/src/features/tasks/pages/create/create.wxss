/* pages/tasks/create/create.wxss */
.page {
  min-height: 100vh;
  background-color: var(--background-color);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: var(--surface-color);
  border-bottom: 1rpx solid var(--border-color);
}

.nav-btn {
  font-size: 32rpx;
  color: var(--text-color);
  padding: 8rpx 16rpx;
}

.nav-btn.primary {
  color: var(--primary-color);
  font-weight: 500;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.content {
  flex: 1;
  padding: 24rpx;
}

.card {
  background-color: var(--surface-color);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card.special {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
}

.title-row {
  display: flex;
  align-items: center;
}

.title-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--text-color);
}

.title-placeholder {
  color: var(--text-secondary);
}

.field-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.field-row:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 32rpx;
  color: var(--text-color);
  flex: 1;
}

.field-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.field-arrow {
  font-size: 40rpx;
  color: var(--text-secondary);
}

.priority-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.priority-badge.priority-0 {
  background-color: rgba(239, 68, 68, 0.1);
  color: var(--priority-1);
}

.priority-badge.priority-1 {
  background-color: rgba(245, 158, 11, 0.1);
  color: var(--priority-2);
}

.priority-badge.priority-2 {
  background-color: rgba(59, 130, 246, 0.1);
  color: var(--priority-3);
}

.priority-badge.priority-3 {
  background-color: rgba(156, 163, 175, 0.1);
  color: var(--priority-4);
}

.tag-list {
  display: flex;
  gap: 8rpx;
}

.tag-item {
  padding: 4rpx 12rpx;
  background-color: rgba(59, 130, 246, 0.1);
  color: var(--primary-color);
  border-radius: 6rpx;
  font-size: 24rpx;
}

.field-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.description-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.6;
}

.meaning-input {
  width: 100%;
  min-height: 100rpx;
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.6;
}

.hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.subtask-list {
  margin-top: 16rpx;
}

.subtask-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.subtask-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 50%;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
}

.subtask-checkbox {
  flex-shrink: 0;
}

.subtask-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
}

.subtask-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
}

.add-subtask {
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--primary-color);
  text-align: center;
}
