<!-- pages/tasks/create/create.wxml -->
<view class="page" style="{{themeStyle}}">
  <status-banner type="error" message="{{errorMessage}}" />
  <status-banner message="正在处理..." wx:if="{{isLoading}}" />
  <view class="nav-bar">
    <view class="nav-btn" bindtap="onCancel">取消</view>
    <view class="nav-title">新建任务</view>
    <view class="nav-btn primary" bindtap="onSave">保存</view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="card title-card">
      <view class="title-row">
        <input class="title-input" value="{{title}}" bindinput="onTitleInput" placeholder="准备做什么？" placeholder-class="title-placeholder" focus="{{true}}" />
      </view>
      <view class="quick-grid">
        <picker mode="date" value="{{dueDate}}" bindchange="onDateChange">
          <view class="quick-item">
            <text class="quick-icon">📅</text>
            <text class="quick-text">{{dueDate || '日期'}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{dueTime}}" bindchange="onTimeChange">
          <view class="quick-item">
            <text class="quick-icon">⏰</text>
            <text class="quick-text">{{dueTime || '时间'}}</text>
          </view>
        </picker>
        <view class="quick-item" bindtap="onSelectList">
          <text class="quick-icon">📋</text>
          <text class="quick-text">{{currentList.name}}</text>
        </view>
        <view class="quick-item" bindtap="onSelectPriority">
          <text class="quick-icon">🔴</text>
          <text class="quick-text">{{priorityLabels[priority]}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="field-title">标签</view>
      <input class="tag-input" value="{{tagsInput}}" bindinput="onTagsInput" placeholder="输入标签，空格或逗号分隔" />
      <view class="tag-list" wx:if="{{tags.length > 0}}">
        <text class="tag-item" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="card">
      <view class="field-title">描述</view>
      <textarea class="description-input" value="{{description}}" bindinput="onDescriptionInput" placeholder="添加描述..." maxlength="1000" auto-height />
    </view>

    <view class="card special">
      <view class="field-title">✨ 任务意义</view>
      <textarea class="meaning-input" value="{{meaning}}" bindinput="onMeaningInput" placeholder="为什么做这个任务？" maxlength="500" />
      <view class="hint">记录任务的意义，帮助你理解"为什么做"</view>
    </view>

    <view class="card">
      <view class="field-title">子任务</view>
      <view class="subtask-list" wx:if="{{subtasks.length > 0}}">
        <view class="subtask-item" wx:for="{{subtasks}}" wx:key="index">
          <view class="subtask-checkbox" bindtap="onToggleSubtask" data-index="{{index}}">
            <text wx:if="{{item.completed}}">✓</text>
          </view>
          <input class="subtask-input" value="{{item.title}}" bindinput="onSubtaskInput" data-index="{{index}}" placeholder="子任务" />
          <view class="subtask-delete" catchtap="onDeleteSubtask" data-index="{{index}}">×</view>
        </view>
      </view>
      <view class="add-subtask" bindtap="onAddSubtask">
        <text>+ 添加子任务</text>
      </view>
    </view>
  </scroll-view>
</view>
