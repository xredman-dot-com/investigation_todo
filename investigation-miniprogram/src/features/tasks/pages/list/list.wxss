/* pages/tasks/list/list.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  background: var(--color-bg);
  gap: 16rpx;
}

.menu-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-soft);
}

.search-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--color-text-muted);
  box-shadow: var(--shadow-soft);
}

.list-indicator {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 24rpx 12rpx;
  padding: 14rpx 20rpx;
  background: var(--color-surface);
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border);
}

.list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.list-arrows {
  display: flex;
  gap: 16rpx;
  font-size: 32rpx;
  color: var(--color-text-muted);
}

.tasks-swiper {
  flex: 1;
  height: 0;
}

.tasks-scroll {
  height: 100%;
  padding: 12rpx 24rpx 120rpx;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin: 12rpx 0 14rpx;
  padding-left: 6rpx;
  letter-spacing: 1rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 1000;
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  line-height: 1;
}

.swipe-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 2000;
}

.swipe-panel.show {
  opacity: 1;
  pointer-events: auto;
}

.swipe-actions {
  width: 100%;
  background: var(--color-surface);
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 24rpx;
  display: flex;
  gap: 16rpx;
  border: 1rpx solid var(--color-border);
}

.swipe-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #101010;
}

.swipe-btn.success {
  background-color: var(--color-success);
}

.swipe-btn.primary {
  background-color: var(--color-accent);
}

.swipe-btn.danger {
  background-color: var(--color-danger);
}
